function doGet(e) {
  try {
    const params = (e && e.parameter) || {};
    const action = params.action || "ping";

    if (action === "ping") return output(params, { status: "ok" });
    assertAuthorized(params);
    if (action === "getEmployees") return output(params, getEmployeesData());
    if (action === "getLeaves") return output(params, getLeavesData());
    if (action === "getMyLeaves") return output(params, getMyLeavesData(params.name));
    if (action === "getMyOT") return output(params, getMyOTData(params.name));
    if (action === "getSchedule") return output(params, getScheduleData());
    if (action === "getHolidays") return output(params, getHolidaysData());
    if (action === "getQuota") return output(params, getQuotaData(params.name, params.userId));

    return output(params, { status: "error", message: "Unknown action: " + action });
  } catch (err) {
    const params = (e && e.parameter) || {};
    return output(params, { status: "error", message: String(err && err.message ? err.message : err) });
  }
}

function doPost(e) {
  try {
    const data = parseBody(e);
    const action = data.action || "";
    assertAuthorized(data);

    if (action === "checkin") return jsonOutput(doCheckin(data));
    if (action === "leave") return jsonOutput(doLeave(data));
    if (action === "cancelLeave") return jsonOutput(doCancelLeave(data));
    if (action === "ot") return jsonOutput(doOT(data));
    if (action === "cancelOT") return jsonOutput(doCancelOT(data));

    return jsonOutput({ status: "error", message: "Unknown action: " + action });
  } catch (err) {
    return jsonOutput({ status: "error", message: String(err && err.message ? err.message : err) });
  }
}

function getEmployeesData() {
  const sheet = getSheet(SHEETS.employees);
  const values = sheet.getDataRange().getValues();
  const headerIndex = findRow(values, "รหัส", 0);
  if (headerIndex < 0) throw new Error("Header not found: รหัส in " + sheet.getName());
  const employees = [];

  values.slice(headerIndex + 1).forEach(row => {
    if (isEmptyRow(row)) return;
    if (clean(row[0]).indexOf("💡") === 0) return;
    const name = clean(row[1]);
    const role = clean(row[2]);
    if (name && role === "พนักงาน") {
      employees.push({
        id: clean(row[0]),
        name,
        role,
        phone: clean(row[3]),
        startDate: toDisplayDate(row[4]),
        salary: row[5] || "",
        otRate: Number(row[6]) || 0,
        dayOff: clean(row[7]),
        userId: clean(row[8]),
        note: clean(row[9])
      });
    }
  });

  return { status: "ok", names: employees.map(emp => emp.name), employees };
}

function getLeavesData() {
