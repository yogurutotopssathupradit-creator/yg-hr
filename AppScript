function writeDataRow(sheet, firstHeaderText, values) {
  const all = sheet.getDataRange().getValues();
  let headerIndex = findRow(all, firstHeaderText, 0);
  if (headerIndex < 0) headerIndex = getFlexibleTable(sheet, firstHeaderText).headerRow - 1;
  if (headerIndex < 0) throw new Error("Header not found: " + firstHeaderText + " in " + sheet.getName());

  let targetRow = all.length + 1;
  for (let r = headerIndex + 1; r < all.length; r++) {
    const first = clean(all[r][0]);
    if (isEmptyRow(all[r])) {
      targetRow = r + 1;
      break;
    }
    if (first.indexOf("💡") === 0 || first.indexOf("📋") === 0) {
      targetRow = r + 1;
      sheet.insertRowBefore(targetRow);
      break;
    }
  }

  sheet.getRange(targetRow, 1, 1, values.length).setValues([values]);
  return targetRow;
}

function writeDataRowAtTop(sheet, firstHeaderText, values) {
  const table = getFlexibleTable(sheet, firstHeaderText);
  const targetRow = table.headerRow + 1;
  sheet.insertRowBefore(targetRow);
  sheet.getRange(targetRow, 1, 1, values.length).setValues([values]);
  return targetRow;
}

function applyValidationFromNearbyRow(sheet, targetRow, col) {
  const target = sheet.getRange(targetRow, col);
  if (target.getDataValidation()) return;

  for (let row = targetRow - 1; row >= 1; row--) {
    const validation = sheet.getRange(row, col).getDataValidation();
    if (validation) {
      target.setDataValidation(validation);
      return;
    }
  }

  for (let row = targetRow + 1; row <= sheet.getLastRow(); row++) {
    const validation = sheet.getRange(row, col).getDataValidation();
    if (validation) {
      target.setDataValidation(validation);
      return;
    }
  }
}

function ensureTableHeaderColumn(sheet, firstHeaderText, headerText) {
  const table = getFlexibleTable(sheet, firstHeaderText);
  const headerRange = sheet.getRange(table.headerRow, 1, 1, sheet.getLastColumn());
  const headers = headerRange.getValues()[0];
  if (headers.some(cell => clean(cell) === headerText)) return;

  let targetCol = headers.length + 1;
  for (let i = headers.length - 1; i >= 0; i--) {
    if (clean(headers[i])) {
      targetCol = i + 2;
      break;
    }
  }
  sheet.getRange(table.headerRow, targetCol).setValue(headerText);
}

function findRow(values, firstCellText, col, startIndex) {
  const start = startIndex || 0;
  for (let r = start; r < values.length; r++) {
    if (clean(values[r][col]) === firstCellText) return r;
  }
  return -1;
}

function parseBody(e) {
  if (!e || !e.postData || !e.postData.contents) return {};
