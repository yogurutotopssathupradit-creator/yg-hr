function getScheduleWeek(values, shiftHeader) {
  if (shiftHeader < 0) return "";
  for (let r = shiftHeader + 1; r < values.length; r++) {
    const first = clean(values[r][0]);
    if (first === "สัปดาห์ที่:") return clean(values[r][1]);
    if (first && first !== "สัปดาห์ที่:" && first.indexOf("💡") !== 0) continue;
  }
  return "";
}

