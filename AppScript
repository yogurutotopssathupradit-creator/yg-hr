function getScheduleData() {
  const sheet = getSheet(SHEETS.schedule);
  const values = sheet.getDataRange().getValues();
  const days = ["จันทร์", "อังคาร", "พุธ", "พฤหัส", "ศุกร์", "เสาร์", "อาทิตย์"];
  const shiftHeader = findRow(values, "พนักงาน", 0);
  const positionHeader = findRow(values, "พนักงาน", 0, shiftHeader + 1);
  const week = getScheduleWeek(values, shiftHeader);
  const shifts = [];
  const shiftTimes = parseShiftTimes(values);
  const positions = [];
  const employeeNames = getEmployeesData().names;

  if (shiftHeader < 0) return { status: "ok", week: "", days, shifts, shiftTimes, positions };

  for (let r = shiftHeader + 1; r < values.length; r++) {
    if (positionHeader > -1 && r >= positionHeader) break;
    const name = clean(values[r][0]);
    if (!name || name.indexOf("💡") === 0 || name === "สัปดาห์ที่:") continue;
    if (employeeNames.indexOf(name) === -1) continue;

    const item = { name, days: {} };
    days.forEach((day, idx) => {
      item.days[day] = { shift: clean(values[r][idx + 1]), position: "" };
    });
    shifts.push(item);
  }

  if (positionHeader > -1) {
    for (let r = positionHeader + 1; r < values.length; r++) {
      const name = clean(values[r][0]);
      if (!name || name.indexOf("💡") === 0 || name === "สัปดาห์ที่:") continue;
      if (employeeNames.indexOf(name) === -1) continue;
      const item = shifts.filter(s => s.name === name)[0];
      if (!item) continue;
      days.forEach((day, idx) => {
        const position = clean(values[r][idx + 1]);
        item.days[day].position = position;
        if (position && position !== "-" && positions.indexOf(position) === -1) positions.push(position);
      });
    }
  }

  return { status: "ok", week, days, shifts, shiftTimes, positions };
}

