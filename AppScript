function isEmployeeScheduleConfigEdit_(e) {
  if (!e || !e.range) return true;
  const sheet = e.range.getSheet();
  const values = sheet.getDataRange().getValues();
  const headerIndex = findRow(values, "รหัส", 0);
  if (headerIndex < 0) return true;
  const headers = getHeaderMap(values[headerIndex]);
  const watchedColumns = [
    2,
    Number(headers["วันหยุดประจำ"]) + 1,
    Number(headers["ตำแหน่งหลัก"]) + 1,
    Number(headers["กะหลัก"]) + 1
  ].filter(Boolean);
  const firstCol = e.range.getColumn();
  const lastCol = firstCol + e.range.getNumColumns() - 1;
  return watchedColumns.some(col => col >= firstCol && col <= lastCol);
}

function syncMonthlySalary(targetDate, ss) {
  const date = targetDate || new Date();
  const period = getMonthPeriod(date);
  const employees = getEmployeesData().employees;
  const checkins = calculateMonthlyCheckins(period.start, period.end, ss);
  const leaves = calculateMonthlyLeaveSummary(period.start, period.end, ss);
  const ot = calculateMonthlyOtSummary(period.start, period.end, ss);
  const currentManual = getCurrentSalaryManualValues(ss);
  const sheet = getSheet(SHEETS.salary, ss);
  const table = getFlexibleTable(sheet, "ชื่อ");
  const rows = [];
  const totals = {
    salary: 0,
    workDays: 0,
    paidLeave: 0,
    unpaidLeave: 0,
    normalPay: 0,
    holidayWorked: 0,
    holidayExtra: 0,
    ot: 0,
    diligence: 0,
    incentive: 0,
    net: 0
  };

  employees.forEach(emp => {
    const salary = parseMoney(emp.salary);
    const dailyRate = salary / 30;
    const name = emp.name;
    const workDays = Number((checkins[name] && checkins[name].workDays) || 0);
    const holidayWorked = Number((checkins[name] && checkins[name].holidayWorked) || 0);
    const paidLeave = Number((leaves[name] && leaves[name].paid) || 0);
    const unpaidLeave = Number((leaves[name] && leaves[name].unpaid) || 0);
    const otTotal = Number((ot[name] && ot[name].total) || 0);
    const manual = currentManual[name] || {};
    const diligence = Number(manual.diligence) || 0;
    const incentive = Number(manual.incentive) || 0;
    const normalPay = Math.max(Math.round((dailyRate * workDays) - (unpaidLeave * 400)), 0);
    const holidayExtra = holidayWorked * 200;
    const net = normalPay + holidayExtra + otTotal + diligence + incentive;

    totals.salary += salary;
    totals.workDays += workDays;
    totals.paidLeave += paidLeave;
    totals.unpaidLeave += unpaidLeave;
    totals.normalPay += normalPay;
    totals.holidayWorked += holidayWorked;
    totals.holidayExtra += holidayExtra;
    totals.ot += otTotal;
    totals.diligence += diligence;
    totals.incentive += incentive;
    totals.net += net;

    rows.push([
      name,
      salary,
      workDays,
      paidLeave,
      unpaidLeave,
      normalPay,
      holidayWorked,
      holidayExtra,
      otTotal,
      diligence,
      incentive,
      net
    ]);
  });

  rows.push([
    "รวมทั้งหมด",
    totals.salary,
    totals.workDays,
    totals.paidLeave,
    totals.unpaidLeave,
    totals.normalPay,
    totals.holidayWorked,
    totals.holidayExtra,
    totals.ot,
    totals.diligence,
    totals.incentive,
    totals.net
  ]);

  sheet.getRange(table.headerRow, 2).setValue(period.label + " เงินเดือนฐาน");
  ensureSalaryRows(sheet, table, rows.length);
  sheet.getRange(table.headerRow + 1, 1, rows.length, 12).setValues(rows);
  return { status: "ok", month: period.label, rows: rows.length };
}

function calculateMonthlyCheckins(start, end, ss) {
  const sheet = getSheet(SHEETS.checkins, ss);
  const table = getFlexibleTable(sheet, "วันที่");
  const byName = {};
  table.rows.forEach(row => {
    const dateKey = normalizeDateKey(row[0]);
    if (!dateKey || dateKey < start || dateKey > end) return;
    if (clean(row[2]) !== "เช็คอิน") return;
    const name = clean(row[1]);
    if (!name) return;
    if (!byName[name]) byName[name] = { dates: {}, holidayDates: {} };
    byName[name].dates[dateKey] = true;
    if (checkHoliday(dateKey)) byName[name].holidayDates[dateKey] = true;
  });

  const summary = {};
  Object.keys(byName).forEach(name => {
    summary[name] = {
      workDays: Object.keys(byName[name].dates).length,
      holidayWorked: Object.keys(byName[name].holidayDates).length
    };
  });
  return summary;
}

function calculateMonthlyLeaveSummary(start, end, ss) {
  const sheet = getSheet(SHEETS.leaves, ss);
  const table = getFlexibleTable(sheet, "วันที่ยื่น");
  const summary = {};
  table.rows.forEach(row => {
    const name = clean(row[1]);
    const type = clean(row[2]);
    const dateKey = normalizeDateKey(row[3]);
    const status = clean(row[7]);
    if (!name || status !== "อนุมัติ" || !dateKey || dateKey < start || dateKey > end) return;
    if (!summary[name]) summary[name] = { paid: 0, unpaid: 0 };
    const days = Number(row[5]) || 1;
    if (type === "ลาไม่รับเงิน") summary[name].unpaid += days;
    else summary[name].paid += days;
  });
  return summary;
}

function calculateMonthlyOtSummary(start, end, ss) {
  const sheet = getSheet(SHEETS.ot, ss);
  const table = getFlexibleTable(sheet, "วันที่");
  const summary = {};
  table.rows.forEach(row => {
    const name = clean(row[1]);
    const dateKey = normalizeDateKey(row[0]);
    const status = clean(row[8]);
    if (!name || status !== "อนุมัติ" || !dateKey || dateKey < start || dateKey > end) return;
    if (!summary[name]) summary[name] = { total: 0 };
    summary[name].total += Number(row[6]) || 0;
  });
  return summary;
}

function getCurrentSalaryManualValues(ss) {
  const sheet = getSheet(SHEETS.salary, ss);
  const table = getFlexibleTable(sheet, "ชื่อ");
  const values = {};
  table.rows.forEach(row => {
    const name = clean(row[0]);
    if (!name) return;
    values[name] = {
      diligence: parseMoney(row[9]),
      incentive: parseMoney(row[10])
    };
  });
  return values;
}

function ensureSalaryRows(sheet, table, neededRows) {
  const existingRows = table.rows.length;
  const firstNoteRow = table.headerRow + 1 + existingRows;
  if (existingRows < neededRows) {
    sheet.insertRowsBefore(firstNoteRow, neededRows - existingRows);
  }
  if (existingRows > neededRows) {
    sheet.getRange(table.headerRow + 1 + neededRows, 1, existingRows - neededRows, 12).clearContent();
  }
}

function getMonthPeriod(date) {
  const monthStart = new Date(date.getFullYear(), date.getMonth(), 1);
  const monthEnd = new Date(date.getFullYear(), date.getMonth() + 1, 0);
  return {
    start: Utilities.formatDate(monthStart, TIMEZONE, "yyyy-MM-dd"),
    end: Utilities.formatDate(monthEnd, TIMEZONE, "yyyy-MM-dd"),
    label: THAI_MONTH_NAMES[date.getMonth()] + " " + (date.getFullYear() + 543)
  };
}

function calculateApprovedLeaveUsage(ss) {
  const sheet = getSheet(SHEETS.leaves, ss);
  const table = getFlexibleTable(sheet, "วันที่ยื่น");
  const usage = {};

  table.rows.forEach(row => {
    const name = clean(row[1]);
    const type = clean(row[2]);
    const days = Number(row[5]) || 1;
    const status = clean(row[7]);
    if (!name || !type || status !== "อนุมัติ") return;
    if (!usage[name]) usage[name] = {};
    usage[name][type] = (Number(usage[name][type]) || 0) + days;
  });

  return usage;
}

