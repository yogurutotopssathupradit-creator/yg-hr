function syncLeaveQuota(ss) {
  const approved = calculateApprovedLeaveUsage(ss);
  const sheet = getSheet(SHEETS.quota, ss);
  const table = getFlexibleTable(sheet, "ชื่อ");

  table.rows.forEach((row, index) => {
    const name = clean(row[0]);
    if (!name || name.indexOf("📋") === 0 || name.indexOf("💡") === 0) return;
    const usage = approved[name] || {};
    const sheetRow = table.headerRow + 1 + index;

    const sickUsed = Number(usage["ลาป่วย"]) || 0;
    const businessUsed = Number(usage["ลากิจ"]) || 0;
    const vacationUsed = Number(usage["ลาพักร้อน"]) || 0;
    const unpaidUsed = Number(usage["ลาไม่รับเงิน"]) || 0;

    sheet.getRange(sheetRow, 3).setValue(sickUsed);
    sheet.getRange(sheetRow, 4).setValue(Math.max((Number(row[1]) || 0) - sickUsed, 0));
    sheet.getRange(sheetRow, 6).setValue(businessUsed);
    sheet.getRange(sheetRow, 7).setValue(Math.max((Number(row[4]) || 0) - businessUsed, 0));
    sheet.getRange(sheetRow, 9).setValue(vacationUsed);
    sheet.getRange(sheetRow, 10).setValue(Math.max((Number(row[7]) || 0) - vacationUsed, 0));
    sheet.getRange(sheetRow, 11).setValue(unpaidUsed);
  });

  return { status: "ok" };
}

