function clean(value) {
  if (value === null || value === undefined) return "";
  return String(value).trim();
}

function parseMoney(value) {
  return Number(clean(value).replace(/,/g, "")) || 0;
}

function isEmptyRow(row) {
  return row.every(cell => clean(cell) === "");
}

function parseDate(value) {
  if (Object.prototype.toString.call(value) === "[object Date]" && !isNaN(value.getTime())) return value;
  const text = clean(value);
  if (!text) return null;

  let match = text.match(/^(\d{4})-(\d{1,2})-(\d{1,2})$/);
  if (match) return new Date(Number(match[1]), Number(match[2]) - 1, Number(match[3]));

  match = text.match(/^(\d{4})-(\d{1,2})-(\d{1,2})\s+(\d{1,2}):(\d{2})(?::(\d{2}))?$/);
  if (match) return new Date(Number(match[1]), Number(match[2]) - 1, Number(match[3]), Number(match[4]), Number(match[5]), Number(match[6]) || 0);

  match = text.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
  if (match) return new Date(Number(match[3]), Number(match[2]) - 1, Number(match[1]));

  match = text.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})\s+(\d{1,2}):(\d{2})(?::(\d{2}))?$/);
  if (match) return new Date(Number(match[3]), Number(match[2]) - 1, Number(match[1]), Number(match[4]), Number(match[5]), Number(match[6]) || 0);

  return null;
}

function normalizeDateKey(value) {
  const date = parseDate(value);
  if (!date) return "";
  return Utilities.formatDate(date, TIMEZONE, "yyyy-MM-dd");
}

function toDisplayDate(value) {
  const date = parseDate(value);
  if (!date) return clean(value);
  return Utilities.formatDate(date, TIMEZONE, "dd/MM/yyyy");
}

function toDisplayDateTime(value) {
  const date = parseDate(value);
  if (!date) return clean(value);
  return Utilities.formatDate(date, TIMEZONE, "dd/MM/yyyy HH:mm:ss");
}

function toDisplayTime(value) {
  if (Object.prototype.toString.call(value) === "[object Date]" && !isNaN(value.getTime())) {
    return Utilities.formatDate(value, TIMEZONE, "HH:mm");
  }
  const text = clean(value);
  const match = text.match(/(\d{1,2}):(\d{2})/);
  if (match) return String(match[1]).padStart(2, "0") + ":" + match[2];
  return text;
}

function parseDateTimeValue(value) {
  const date = parseDate(value);
  return date ? date.getTime() : 0;
}

function thaiDayName(date) {
  const names = ["อาทิตย์", "จันทร์", "อังคาร", "พุธ", "พฤหัส", "ศุกร์", "เสาร์"];
  return names[date.getDay()];
}

function calculateHours(start, end) {
  const s = clean(start).split(":").map(Number);
  const e = clean(end).split(":").map(Number);
  if (s.length < 2 || e.length < 2) return 0;
  return Math.round(((e[0] * 60 + e[1]) - (s[0] * 60 + s[1])) / 60 * 10) / 10;
}

function parseShiftTimes(values) {
  const shiftTimes = {};
  values.forEach(row => {
    row.forEach(cell => {
      const text = clean(cell);
      if (!text) return;
      const matches = text.match(/กะ\s*(\d+)\s*=\s*([0-9:.]+)\s*[-–]\s*([0-9:.]+)/g);
      if (!matches) return;
      matches.forEach(match => {
        const parts = match.match(/กะ\s*(\d+)\s*=\s*([0-9:.]+)\s*[-–]\s*([0-9:.]+)/);
        if (parts) shiftTimes["กะ " + parts[1]] = parts[2].replace(".", ":") + "–" + parts[3].replace(".", ":");
      });
    });
  });
  return shiftTimes;
}

function autoFillSchedule() {
  const sheet = getSheet(SHEETS.schedule);
  const employees = getEmployeesData().employees;
  const schedule = getScheduleData();
  const positions = schedule.positions;
  const shiftOptions = Object.keys(schedule.shiftTimes);
  if (!positions.length) throw new Error("No positions found in schedule sheet");
  if (!shiftOptions.length) throw new Error("No shift times found in schedule sheet");
  const days = ["จันทร์", "อังคาร", "พุธ", "พฤหัส", "ศุกร์", "เสาร์", "อาทิตย์"];
  const now = new Date();
  const weeks = Math.floor(now.getTime() / (7 * 24 * 3600 * 1000));
  const rotation = Math.floor(weeks / 2) % positions.length;
  const shiftRotation = Math.floor(weeks / 2) % shiftOptions.length;

  const day = now.getDay();
  const monday = new Date(now);
  monday.setDate(now.getDate() - (day === 0 ? 6 : day - 1));
  const sunday = new Date(monday);
  sunday.setDate(monday.getDate() + 6);
  const weekStr = Utilities.formatDate(monday, TIMEZONE, "dd/MM") + " - " + Utilities.formatDate(sunday, TIMEZONE, "dd/MM/yyyy");

  sheet.getRange("B4").setValue(weekStr);
  sheet.getRange("B12").setValue(weekStr);

  employees.forEach((emp, idx) => {
    sheet.getRange(5 + idx, 1).setValue(emp.name);
    sheet.getRange(13 + idx, 1).setValue(emp.name);
    const shift = normalizeRotateValue(emp.fixedShift) || shiftOptions[(idx + shiftRotation) % shiftOptions.length];
    const position = normalizeRotateValue(emp.fixedPosition) || positions[(idx + rotation) % positions.length];

    days.forEach((dayName, dayIndex) => {
      const isOff = emp.dayOff && emp.dayOff.indexOf(dayName) !== -1;
      sheet.getRange(5 + idx, 2 + dayIndex).setValue(isOff ? "หยุด" : shift);
      sheet.getRange(13 + idx, 2 + dayIndex).setValue(isOff ? "-" : position);
    });
  });

  return { status: "ok" };
}

function setAllTriggers() {
  ScriptApp.getProjectTriggers().forEach(trigger => ScriptApp.deleteTrigger(trigger));
  ScriptApp.newTrigger("autoFillSchedule")
    .timeBased()
    .onWeekDay(ScriptApp.WeekDay.MONDAY)
    .atHour(6)
    .create();
  ScriptApp.newTrigger("syncLeaveQuota")
    .timeBased()
    .everyMinutes(10)
    .create();
  ScriptApp.newTrigger("syncMonthlySalary")
    .timeBased()
    .onMonthDay(28)
    .atHour(6)
    .create();
  ScriptApp.newTrigger("handleSheetEdit")
    .forSpreadsheet(getSs())
    .onEdit()
    .create();
}
