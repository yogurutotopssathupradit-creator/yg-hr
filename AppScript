function getSs() {
  return SpreadsheetApp.openById(SPREADSHEET_ID);
}

function getSheet(name) {
  const sheet = getSs().getSheetByName(name);
  if (!sheet) throw new Error("Sheet not found: " + name);
  return sheet;
}

function getTable(sheet, firstHeaderText) {
  const values = sheet.getDataRange().getValues();
  const headerIndex = findRow(values, firstHeaderText, 0);
  if (headerIndex < 0) throw new Error("Header not found: " + firstHeaderText + " in " + sheet.getName());

  const rows = [];
  for (let r = headerIndex + 1; r < values.length; r++) {
    const row = values[r];
    const first = clean(row[0]);
    if (first.indexOf("💡") === 0 || first.indexOf("📋") === 0) break;
    if (isEmptyRow(row)) continue;
    rows.push(row);
  }

  return { headerRow: headerIndex + 1, rows };
}

function writeDataRow(sheet, firstHeaderText, values) {
  const all = sheet.getDataRange().getValues();
  const headerIndex = findRow(all, firstHeaderText, 0);
  if (headerIndex < 0) throw new Error("Header not found: " + firstHeaderText + " in " + sheet.getName());

  let targetRow = all.length + 1;
  for (let r = headerIndex + 1; r < all.length; r++) {
    const first = clean(all[r][0]);
    if (isEmptyRow(all[r])) {
      targetRow = r + 1;
      break;
    }
    if (first.indexOf("💡") === 0 || first.indexOf("📋") === 0) {
      targetRow = r + 1;
      sheet.insertRowBefore(targetRow);
      break;
    }
  }

  sheet.getRange(targetRow, 1, 1, values.length).setValues([values]);
}

function findRow(values, firstCellText, col, startIndex) {
  const start = startIndex || 0;
  for (let r = start; r < values.length; r++) {
    if (clean(values[r][col]) === firstCellText) return r;
  }
  return -1;
}

function parseBody(e) {
  if (!e || !e.postData || !e.postData.contents) return {};
  return JSON.parse(e.postData.contents);
}

function jsonOutput(data) {
  return ContentService
    .createTextOutput(JSON.stringify(data))
    .setMimeType(ContentService.MimeType.JSON);
}

function output(params, data) {
  const callback = clean(params.callback);
  if (!callback) return jsonOutput(data);
  if (!/^[A-Za-z_$][0-9A-Za-z_$]*(\.[A-Za-z_$][0-9A-Za-z_$]*)*$/.test(callback)) {
    return jsonOutput({ status: "error", message: "Invalid callback" });
  }
  return ContentService
    .createTextOutput(callback + "(" + JSON.stringify(data) + ");")
    .setMimeType(ContentService.MimeType.JAVASCRIPT);
}

function requireFields(data, fields) {
  fields.forEach(field => {
    if (!clean(data[field])) throw new Error("Missing field: " + field);
  });
}

function assertAuthorized(data) {
  if (clean(data && data.token) !== APP_SECRET) {
    throw new Error("Unauthorized");
  }
}

function clean(value) {
  if (value === null || value === undefined) return "";
  return String(value).trim();
}

function isEmptyRow(row) {
  return row.every(cell => clean(cell) === "");
}

function parseDate(value) {
  if (Object.prototype.toString.call(value) === "[object Date]" && !isNaN(value.getTime())) return value;
  const text = clean(value);
  if (!text) return null;

  let match = text.match(/^(\d{4})-(\d{1,2})-(\d{1,2})$/);
  if (match) return new Date(Number(match[1]), Number(match[2]) - 1, Number(match[3]));

  match = text.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
  if (match) return new Date(Number(match[3]), Number(match[2]) - 1, Number(match[1]));

  return null;
}

function normalizeDateKey(value) {
  const date = parseDate(value);
  if (!date) return "";
  return Utilities.formatDate(date, TIMEZONE, "yyyy-MM-dd");
}

function toDisplayDate(value) {
  const date = parseDate(value);
  if (!date) return clean(value);
  return Utilities.formatDate(date, TIMEZONE, "dd/MM/yyyy");
}

function thaiDayName(date) {
  const names = ["อาทิตย์", "จันทร์", "อังคาร", "พุธ", "พฤหัส", "ศุกร์", "เสาร์"];
  return names[date.getDay()];
}

function calculateHours(start, end) {
  const s = clean(start).split(":").map(Number);
  const e = clean(end).split(":").map(Number);
  if (s.length < 2 || e.length < 2) return 0;
  return Math.round(((e[0] * 60 + e[1]) - (s[0] * 60 + s[1])) / 60 * 10) / 10;
}

function parseShiftTimes(values) {
  const shiftTimes = {};
  values.forEach(row => {
    row.forEach(cell => {
      const text = clean(cell);
      if (!text) return;
      const matches = text.match(/กะ\s*(\d+)\s*=\s*([0-9:.]+)\s*[-–]\s*([0-9:.]+)/g);
      if (!matches) return;
      matches.forEach(match => {
        const parts = match.match(/กะ\s*(\d+)\s*=\s*([0-9:.]+)\s*[-–]\s*([0-9:.]+)/);
        if (parts) shiftTimes["กะ " + parts[1]] = parts[2].replace(".", ":") + "–" + parts[3].replace(".", ":");
      });
    });
  });
  return shiftTimes;
}

function autoFillSchedule() {
  const sheet = getSheet(SHEETS.schedule);
  const employees = getEmployeesData().employees;
  const positions = getScheduleData().positions;
  if (!positions.length) throw new Error("No positions found in schedule sheet");
  const days = ["จันทร์", "อังคาร", "พุธ", "พฤหัส", "ศุกร์", "เสาร์", "อาทิตย์"];
  const now = new Date();
  const weeks = Math.floor(now.getTime() / (7 * 24 * 3600 * 1000));
  const rotation = Math.floor(weeks / 2) % positions.length;

  const day = now.getDay();
  const monday = new Date(now);
  monday.setDate(now.getDate() - (day === 0 ? 6 : day - 1));
  const sunday = new Date(monday);
  sunday.setDate(monday.getDate() + 6);
  const weekStr = Utilities.formatDate(monday, TIMEZONE, "dd/MM") + " - " + Utilities.formatDate(sunday, TIMEZONE, "dd/MM/yyyy");

  sheet.getRange("B4").setValue(weekStr);
  sheet.getRange("B12").setValue(weekStr);

  employees.forEach((emp, idx) => {
    sheet.getRange(5 + idx, 1).setValue(emp.name);
    sheet.getRange(13 + idx, 1).setValue(emp.name);
    const shift = ((Math.floor(weeks / 2) + idx) % 2) + 1;
    const position = positions[(idx + rotation) % positions.length];

    days.forEach((dayName, dayIndex) => {
      const isOff = emp.dayOff && emp.dayOff.indexOf(dayName) !== -1;
      sheet.getRange(5 + idx, 2 + dayIndex).setValue(isOff ? "หยุด" : "กะ " + shift);
      sheet.getRange(13 + idx, 2 + dayIndex).setValue(isOff ? "-" : position);
    });
  });

  return { status: "ok" };
}

function setAllTriggers() {
  ScriptApp.getProjectTriggers().forEach(trigger => ScriptApp.deleteTrigger(trigger));
  ScriptApp.newTrigger("autoFillSchedule")
    .timeBased()
    .onWeekDay(ScriptApp.WeekDay.MONDAY)
    .atHour(6)
    .create();
}
