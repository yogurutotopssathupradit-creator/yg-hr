    hours,
    rate,
    hours * rate,
    isHoliday ? "วันหยุดนักขัตฤกษ์" : "วันธรรมดา",
    "รออนุมัติ",
    submittedAt
  ]);
  applyValidationFromNearbyRow(sheet, row, 9);

  return { status: "ok" };
}

function doCancelOT(data) {
  const row = Number(data.row);
  if (!row) throw new Error("Missing OT row");
  const sheet = getSheet(SHEETS.ot);
  const table = getFlexibleTable(sheet, "วันที่");
  if (row <= table.headerRow) throw new Error("Invalid OT row");
  if (clean(sheet.getRange(row, 2).getValue()) !== clean(data.name)) throw new Error("Employee name does not match row");
