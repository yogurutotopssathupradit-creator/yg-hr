  table.rows.forEach((row, index) => {
    const name = clean(row[1]);
    const startDate = normalizeDateKey(row[3]);
    const status = clean(row[7]) || "รออนุมัติ";
    if (!name || !startDate || status === "ไม่อนุมัติ" || status === "ยกเลิก") return;

    if (!leaves[startDate]) leaves[startDate] = [];
    if (leaves[startDate].indexOf(name) === -1) leaves[startDate].push(name);

    items.push({
      row: table.headerRow + 1 + index,
      submitted: toDisplayDate(row[0]),
      name,
      type: clean(row[2]),
      date: startDate,
      endDate: normalizeDateKey(row[4]),
      days: Number(row[5]) || 1,
      reason: clean(row[6]),
      status
    });
  });

  return { status: "ok", leaves, items };
}

